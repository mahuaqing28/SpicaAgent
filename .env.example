TELEGRAM_BOT_TOKEN=你的telegram_bot_token
TELEGRAM_ALLOWED_CHAT_IDS=你的chat_id

TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_POLL_TIMEOUT=20
TELEGRAM_DROP_PENDING_UPDATES=true

CLAUDE_WORKDIR=/root/projects/SpicaAgent
CLAUDE_TMUX_SESSION=spica_agent
CLAUDE_COMMAND=claude
CLAUDE_ENV_FILE=/root/config/openrouter.txt
CLAUDE_FORWARD_ENV_VARS=HTTP_PROXY,HTTPS_PROXY,ALL_PROXY,NO_PROXY,http_proxy,https_proxy,all_proxy,no_proxy
CLAUDE_READY_TIMEOUT=120
CLAUDE_REPLY_TIMEOUT=600
CLAUDE_CONFIRM_TIMEOUT=300
CLAUDE_HISTORY_LIMIT=100000
CLAUDE_CAPTURE_LINES=2000
CLAUDE_AGENT_ENABLED=false

PHONE_BRIDGE_ENABLED=true
PHONE_BRIDGE_HOST=127.0.0.1
PHONE_BRIDGE_PORT=8765
PHONE_BRIDGE_TOKEN=换成一个长随机token
PHONE_NOTIFY_CHAT_IDS=

SCHEDULE_BRIDGE_ENABLED=true
SCHEDULE_BRIDGE_TOKEN=换成另一个长随机token
SCHEDULE_STATE_FILE=/tmp/spica-agent/schedule-state.json
SCHEDULE_STATESHARE_FILE=
SCHEDULE_NON_WORK_PACKAGES=com.instagram.android,com.google.android.youtube
SCHEDULE_NON_WORK_THRESHOLD_MINUTES=20
SCHEDULE_REMINDER_COOLDOWN_MINUTES=120

SPICA_FILES_ENABLED=true
SPICA_FILE_ROOT=/tmp/spica-agent
SPICA_FILE_OUTPUT_ROOTS=/root/projects/SpicaAgent,/tmp/spica-agent/outputs
SPICA_FILE_ALLOWED_EXTENSIONS=.png,.jpg,.jpeg,.webp,.gif,.pdf,.txt,.md,.zip
SPICA_FILE_MAX_UPLOAD_MB=50
